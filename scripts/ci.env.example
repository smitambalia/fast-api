# Copy to a host path outside git, e.g. ~/.config/fastapi-ci.env
# chmod 600 ~/.config/fastapi-ci.env
# NEVER commit real passwords.

DOCKERHUB_USERNAME=smitambalia
# Access token with Read & Write (Write for push, Read for k3s pull secret)
DOCKERHUB_PASSWORD=change-me-use-access-token
API_IMAGE_REPO=smitambalia/n8n
WEB_IMAGE_REPO=smitambalia/fast-web
REPO_DIR=/home/yashree/development/fast-api
KUBECONFIG_PATH=/home/yashree/.kube/k3s.yaml
# 1 = also load image into k3s containerd after build (needs sudo k3s ctr)
IMPORT_TO_K3S=1
DEPLOY_API=1
DEPLOY_WEB=1
